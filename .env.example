# Supabase (from 'supabase start' output or remote project dashboard)
PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Canonical site URL for outbound email links (welcome email CTA, etc.).
# Optional — defaults to https://librito.io when unset. Self-hosters: set to
# your deployed origin so emails link back to your install. Do NOT derive from
# the request Host header — that's spoofable on misconfigured proxies.
PUBLIC_SITE_URL=https://librito.io

# Realtime JWT signing — /api/realtime-token mints ES256 tokens against the
# Supabase standby signing key. Supabase publishes the public side at
# <project>.supabase.co/auth/v1/.well-known/jwks.json; Realtime verifies
# against that JWKS automatically.
#
# Local dev: see CLAUDE.md "Local dev setup — Realtime signing key" for the
# one-time bootstrap (generate keys, hand-edit supabase/signing_keys.json,
# uncomment signing_keys_path in supabase/config.toml). Then paste the
# standby key's full JWK (including `d`) on a single line below.
#
# Production: generate via `supabase gen signing-key --algorithm ES256`,
# import in Supabase Dashboard → Project Settings → JWT signing keys → "new
# standby key", and set LIBRITO_JWT_PRIVATE_KEY_JWK in Vercel Production env.
# Rotation runbook: docs/ws-rt-follow-ups.md item 8.
LIBRITO_JWT_PRIVATE_KEY_JWK=

# Upstash Redis
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# Resend (email delivery — required for welcome emails in production)
RESEND_API_KEY=re_your-resend-api-key

# Vercel Cron auth — set in Vercel dashboard (production + preview)
CRON_SECRET=
