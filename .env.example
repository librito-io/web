# Supabase (from 'supabase start' output or remote project dashboard)
PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Realtime JWT signing — Librito acts as a third-party JWT issuer registered
# with Supabase (Auth → Third-party Auth → JWKS URL = /.well-known/jwks.json).
# /api/realtime-token mints ES256 tokens against this keypair; Realtime verifies
# via the public JWKS we serve. Generate a fresh ES256 keypair per environment
# (see docs/ws-rt-follow-ups.md → kid rotation runbook).
LIBRITO_JWT_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
LIBRITO_JWT_PUBLIC_KEY_JWK={"kty":"EC","crv":"P-256","x":"...","y":"...","kid":"...","use":"sig","alg":"ES256"}
LIBRITO_JWT_KID=your-kid-uuid
# Per environment: prod=https://librito.io, preview=<vercel-preview-url>, dev=http://localhost:5173
LIBRITO_JWT_ISSUER=https://librito.io

# Upstash Redis
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# Resend (email delivery — required for welcome emails in production)
RESEND_API_KEY=re_your-resend-api-key

# Vercel Cron auth — set in Vercel dashboard (production + preview)
CRON_SECRET=
