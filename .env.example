# Supabase (from 'supabase start' output or remote project dashboard)
PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Canonical site URL for outbound email links (welcome email CTA, etc.).
# Optional — defaults to https://librito.io when unset. Self-hosters: set to
# your deployed origin so emails link back to your install. Do NOT derive from
# the request Host header — that's spoofable on misconfigured proxies.
PUBLIC_SITE_URL=https://librito.io

# Realtime JWT signing — /api/realtime-token mints ES256 tokens against the
# Supabase standby signing key. Supabase publishes the public side at
# <project>.supabase.co/auth/v1/.well-known/jwks.json; Realtime verifies
# against that JWKS automatically.
#
# Local dev: see CLAUDE.md "Local dev setup — Realtime signing key" for the
# one-time bootstrap (generate keys, hand-edit supabase/signing_keys.json,
# uncomment signing_keys_path in supabase/config.toml). Then paste the
# standby key's full JWK (including `d`) on a single line below.
#
# Production: generate via `supabase gen signing-key --algorithm ES256`,
# import in Supabase Dashboard → Project Settings → JWT signing keys → "new
# standby key", and set LIBRITO_JWT_PRIVATE_KEY_JWK in Vercel Production env.
# Rotation runbook: docs/ws-rt-follow-ups.md item 8.
LIBRITO_JWT_PRIVATE_KEY_JWK=

# Upstash Redis
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# Resend (email delivery — required for welcome emails in production)
RESEND_API_KEY=re_your-resend-api-key

# Vercel Cron auth — set in Vercel dashboard (production + preview)
CRON_SECRET=

# Cover storage backend selection. Self-hosters: leave as 'supabase'.
# librito.io production: 'cloudflare-images'.
COVER_STORAGE_BACKEND=supabase

# Cloudflare Images credentials (production only when COVER_STORAGE_BACKEND=cloudflare-images)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_IMAGES_API_TOKEN=
PUBLIC_CLOUDFLARE_IMAGES_HASH=

# NYT Books API key — used by /api/cron/catalog-warmup to pull bestsellers.
# Free tier; sign up at https://developer.nytimes.com/.
NYT_BOOKS_API_KEY=

# Google Books API key — used by the catalog resolver to fetch high-res
# covers (extraLarge >= 1200px) and book descriptions. Anonymous Google
# Books v1 quota is 0/day per project, so a missing key silently degrades
# the entire premium-cover + description path (chain falls through to
# iTunes/OpenLibrary). Free tier ~1000 req/day after enabling the Books API
# in any Google Cloud project. Self-hosters: optional but recommended.
GOOGLE_BOOKS_API_KEY=

# Self-hosters: 'false' (default) skips the weekly warmup cron.
# librito.io production: 'true'.
CATALOG_WARMUP_ENABLED=false

# Self-hosters: 'false' (default) skips the nightly catalog-replay cron
# (retries rows whose per-field fail_reason TTL has elapsed) and the weekly
# catalog-fill-rate cron (snapshots fill rate into catalog_fill_rate_history
# for the admin sparkline). librito.io production: 'true' for both. Marked
# Sensitive in Vercel and read via $env/dynamic/private.
CATALOG_REPLAY_ENABLED=false
CATALOG_FILL_RATE_ENABLED=false

# Sentry — operator error tracking. librito.io uses Sentry to alert on
# runInBackground throws and other unhandled server errors. Self-hosters:
# leave SENTRY_DSN unset and the SDK is a no-op (no events sent); or set
# it to your own Sentry / Sentry-API-compatible endpoint (e.g. self-hosted
# GlitchTip). Free Sentry Developer tier covers expected volume. Marked
# Sensitive in Vercel and read via $env/dynamic/private — see CLAUDE.md
# "Vercel Sensitive env vars require $env/dynamic/private".
SENTRY_DSN=

# Sentry source-map upload (build-time only). When all three are set, the
# Vite plugin uploads compiled source maps so production stack traces map
# back to TypeScript line numbers. Self-hosters without a Sentry org: leave
# unset — build succeeds, stacks land unmapped. Set in Vercel env (preview
# build) AND GitHub Actions secrets (production build inside the
# production-deploy workflow injects directly).
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Sentry client-side error capture. librito.io ships with this set.
# Self-hosters: leave unset to disable browser error reporting (server-
# side errors still fire if SENTRY_DSN is set). The DSN is a public
# identifier, not a secret — safe to expose in the browser bundle.
#
# Vercel env type: Encrypted (NOT Sensitive). Sensitive vars are
# redacted to empty strings by `vercel pull`, which would bake an
# empty DSN into the browser bundle and the client init would silently
# no-op. See CLAUDE.md "Vercel Sensitive env vars require
# $env/dynamic/private" — PUBLIC_SENTRY_DSN is the inverse case.
PUBLIC_SENTRY_DSN=

# Upstash QStash — durable queue for catalog cold-miss resolves.
# Producer (scheduling.ts) publishes one message per work item when
# QSTASH_TOKEN, QSTASH_CONSUMER_URL, and QSTASH_URL are all set; absence
# of any triggers inline runInBackground fallback (today's behavior).
# Consumer route /api/queue/catalog-resolve verifies Upstash-Signature
# using both signing keys (rotation support).
#
# QSTASH_URL pins the region endpoint (e.g.
# https://qstash-eu-central-1.upstash.io for EU tenants). SDK default is
# the global https://qstash.upstash.io; a region-tenant token routed to
# global returns 401 "invalid token".
#
# librito.io production: all five set (Sensitive in Vercel) — read at
# runtime via $env/dynamic/private. Self-hosters / local / preview: leave
# unset to use inline fallback.
QSTASH_TOKEN=
QSTASH_URL=
QSTASH_CONSUMER_URL=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
