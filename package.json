{
  "name": "librito-web",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "lint:css": "stylelint \"src/**/*.css\" \"src/**/*.svelte\"",
    "gen:types": "supabase gen types typescript --local > src/lib/types/database.ts",
    "test": "vitest run",
    "test:integration": "INTEGRATION=1 vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "prepare": "svelte-kit sync && husky",
    "generate-types": "supabase gen types typescript --linked 2>/dev/null > src/lib/types/database.ts"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@playwright/test": "^1.60.0",
    "@sveltejs/adapter-vercel": "^6.3.3",
    "@sveltejs/kit": "^2.61.1",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@types/node": "^22.19.19",
    "husky": "^9.1.7",
    "postcss-html": "^1.8.1",
    "postcss-selector-parser": "^7.1.1",
    "postgres": "^3.4.9",
    "prettier": "^3.8.2",
    "prettier-plugin-svelte": "^3.5.1",
    "stylelint": "^17.12.0",
    "svelte": "^5.56.0",
    "svelte-check": "^4.5.0",
    "tsx": "^4.22.4",
    "typescript": "^5.0.0",
    "vite": "^6.4.3",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/noto-sans-arabic": "^5.2.10",
    "@fontsource/noto-sans-devanagari": "^5.2.8",
    "@fontsource/noto-sans-jp": "^5.2.9",
    "@fontsource/noto-sans-kr": "^5.2.9",
    "@fontsource/noto-sans-sc": "^5.2.9",
    "@sentry/sveltekit": "^10.55.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.2",
    "@upstash/qstash": "^2.11.0",
    "@upstash/ratelimit": "^2.0.0",
    "@upstash/redis": "^1.34.0",
    "@vercel/config": "^0.5.1",
    "@vercel/functions": "^3.6.1",
    "jose": "^6.2.2",
    "marked": "^18.0.4",
    "material-symbols": "^0.44.10",
    "pino": "^9.14.0",
    "resend": "^6.12.4",
    "svelte-bricks": "^0.5.0",
    "svelte-i18n": "^4.0.1"
  },
  "overrides": {
    "cookie": "^0.7.0",
    "path-to-regexp": "^6.3.0",
    "esbuild": ">=0.25.0"
  },
  "type": "module"
}
