{
  "name": "librito-web",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "gen:types": "supabase gen types typescript --local > src/lib/types/database.ts",
    "test": "vitest run",
    "test:integration": "INTEGRATION=1 vitest run --config vitest.integration.config.ts",
    "prepare": "svelte-kit sync",
    "generate-types": "supabase gen types typescript --linked 2>/dev/null > src/lib/types/database.ts"
  },
  "devDependencies": {
    "@sveltejs/adapter-vercel": "^6.3.3",
    "@sveltejs/kit": "^2.21.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@types/node": "^22.19.19",
    "postgres": "^3.4.9",
    "prettier": "^3.8.2",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.55.7",
    "svelte-check": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@fontsource/bitter": "^5.2.10",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/noto-sans": "^5.2.10",
    "@sentry/sveltekit": "^10.53.1",
    "@supabase/ssr": "^0.6.0",
    "@supabase/supabase-js": "^2.49.0",
    "@upstash/ratelimit": "^2.0.0",
    "@upstash/redis": "^1.34.0",
    "@vercel/config": "^0.2.1",
    "@vercel/functions": "^3.6.0",
    "jose": "^6.2.2",
    "marked": "^18.0.2",
    "material-symbols": "^0.44.1",
    "pino": "^9.14.0",
    "resend": "^6.12.0",
    "svelte-i18n": "^4.0.1"
  },
  "overrides": {
    "cookie": "^0.7.0",
    "path-to-regexp": "^6.3.0",
    "esbuild": ">=0.25.0"
  },
  "type": "module"
}
